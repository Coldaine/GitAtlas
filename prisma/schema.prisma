generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id               String    @id @default(cuid())
  githubId         Int       @unique
  name             String
  fullName         String
  description      String?
  htmlUrl          String
  homepage         String?
  language          String?
  stargazersCount  Int       @default(0)
  forksCount       Int       @default(0)
  openIssuesCount  Int       @default(0)
  githubCreatedAt  DateTime
  githubUpdatedAt  DateTime
  pushedAt         DateTime?
  topics           String    @default("")
  isFork           Boolean   @default(false)
  isArchived       Boolean   @default(false)
  ownerLogin       String
  ownerType        String    @default("User")
  ownerAvatarUrl   String?
  defaultBranch    String    @default("main")
  visibility       String    @default("public")
  summary          String?
  tags             String?
  category         String?
  readmeContent    String?
  analyzedAt       DateTime?
  createdAt        DateTime  @default(now())

  // Deep analysis fields
  fileTree         String?   // JSON string of file tree structure
  dependencies     String?   // JSON string of parsed dependencies
  keyFiles         String?   // JSON string of key file contents {path, content, purpose}
  deepSummary      String?   // Richer summary based on actual code analysis
  deepAnalyzedAt   DateTime?
  proposedReadme   String?   // AI-generated README based on actual code
  readmeGeneratedAt DateTime?
  similarProjects  String?   // JSON string of similar project IDs + reasons
  codeSignature    String?   // JSON string of code patterns/technologies detected
}

model AnalysisJob {
  id            String   @id @default(cuid())
  username      String
  status        String   @default("pending")
  totalRepos    Int      @default(0)
  processedRepos Int     @default(0)
  jobType       String   @default("shallow")  // shallow, deep, readme
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommitActivityCache {
  id            String   @id @default(cuid())
  username      String   @unique
  activityJson  String   // JSON string of activity array
  totalCommits  Int      @default(0)
  activeDays    Int      @default(0)
  fetchedAt     DateTime @default(now())
}

model RecentCommitsCache {
  id          String   @id @default(cuid())
  username    String   @unique
  commitsJson String   // JSON string of recent commits array
  fetchedAt   DateTime @default(now())
}
