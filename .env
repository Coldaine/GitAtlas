# GitAtlas local env. See .env.example for the full list of supported vars.
# NOTE: the old hardcoded path `/home/z/my-project/db/custom.db` was a Linux
# absolute path baked in by the upstream template. Switched to a relative path
# so this repo works on Windows / Mac / Linux without surgery.
DATABASE_URL="file:./db/custom.db"

# GitHub PAT — rotate the old hardcoded token in github-token.ts immediately.
GITHUB_TOKEN=

# OpenAI-compatible LLM endpoint. Point at OpenAI, OpenRouter, Ollama, etc.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Sync worker (mini-services/sync-worker.ts)
SYNC_BASE_URL=http://localhost:3000
SYNC_USERNAME=Coldaine
SYNC_REFRESH_INTERVAL=900
SYNC_ENRICH_INTERVAL=60
